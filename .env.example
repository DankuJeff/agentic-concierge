# Agentic Concierge — Environment Variables
# Copy to .env: cp .env.example .env

# ── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (matches docker-compose.yml defaults) ──────────
DATABASE_URL=postgresql://concierge:localdev@localhost:5432/concierge

# ── Redis (matches docker-compose.yml defaults) ─────────────
REDIS_URL=redis://localhost:6379

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Google OAuth2 (Phase 4 — Auth) ──────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/auth/google/callback as an Authorized Redirect URI
# 4. Add http://localhost:5173 as an Authorized JavaScript Origin
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
FRONTEND_ORIGIN=http://localhost:5173

# ── Encryption (Phase 4 — Block 3) ─────────────────────────
# Required. Encrypts document content and Google OAuth tokens at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Stripe Billing (Phase 4 — Block 4) ─────────────────────
# Test mode keys start with sk_test_ / pk_test_.
# Get them from: Stripe Dashboard → Developers → API keys
# Get STRIPE_PRICE_ID from: Stripe Dashboard → Products → (your Pro plan price ID)
# Get STRIPE_WEBHOOK_SECRET from:
#   Production: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
#   Local dev:  stripe listen --forward-to localhost:3000/billing/webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Plaid Financial Data (Phase 4 — Block 4) ────────────────
# Sandbox credentials from: Plaid Dashboard → Team Settings → Keys
# Use environment=sandbox for testing.
PLAID_CLIENT_ID=
PLAID_SECRET=
